          "name": "Exchange authorization code for tokens",
          "request": {
            "name": "Exchange authorization code for tokens",
            "description": {
              "content": "Exchanges an authorization code obtained from the authorization callback for an access token and a refresh token. The access token is valid for 60 days and is used to authenticate API requests on behalf of the user. The refresh token can be used to obtain a new access token when the current one expires.",
              "type": "text/plain"
            },
            "url": {
              "protocol": "https",
              "path": [
                "v1",
                "tokens"
              ],
              "host": [
                "api",
                "medium",
                "com"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "disabled": false,
                  "key": "code",
                  "value": "<string>",
                  "description": "(Required) The authorization code received from the authorization callback redirect."
                },
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) The client ID of the application."
                },
                {
                  "disabled": false,
                  "key": "client_secret",
                  "value": "<string>",
                  "description": "(Required) The client secret of the application."
                },
                {
                  "disabled": false,
                  "key": "grant_type",
                  "value": "<string>",
                  "description": "(Required) Must be set to \"authorization_code\" for the initial token exchange."
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) The same redirect URI used during the authorization request."
                }
              ]
