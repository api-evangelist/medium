  "item": [
    {
      "id": "76f611f7-8f79-4125-9926-9b5447bc71eb",
      "name": "Authorization",
      "description": {
        "content": "Endpoints for initiating the OAuth2 authorization flow by redirecting users to Medium's authorization page.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "53abf71d-f265-48f8-a904-b26f6cd76215",
          "name": "Authorize a user via OAuth2",
          "request": {
            "name": "Authorize a user via OAuth2",
            "description": {
              "content": "Redirects the user to Medium's authorization page where they can grant the application access to their account. The application specifies the desired scopes and a state parameter for CSRF protection. Upon successful authorization, Medium redirects the user back to the specified redirect URI with an authorization code and the state parameter.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "authorize"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) The client ID of the application as registered with Medium."
                },
                {
                  "disabled": false,
                  "key": "scope",
                  "value": "<string>",
                  "description": "(Required) A comma-separated list of requested permissions. Available scopes are basicProfile, listPublications, publishPost, and uploadImage. The uploadImage scope is an extended scope that requires prior authorization from Medium."
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "(Required) An arbitrary string used to prevent cross-site request forgery attacks. This value is returned unchanged in the callback."
                },
                {
                  "disabled": false,
                  "key": "response_type",
                  "value": "<string>",
                  "description": "(Required) Must be set to \"code\" to indicate the authorization code grant flow."
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) The URL where Medium will redirect the user after authorization. Must match one of the redirect URIs registered for the application."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "36caa54b-ddaf-4bf5-ad15-ba99f73639ca",
              "name": "Redirects the user to Medium's authorization page. After the user grants or denies access, they are redirected to the specified redirect URI with the authorization code and state as query parameters.",
              "originalRequest": {
                "url": {
                  "path": [
                    "authorize"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "client_id",
                      "value": "<string>"
                    },
                    {
                      "key": "scope",
                      "value": "<string>"
                    },
                    {
                      "key": "state",
                      "value": "<string>"
                    },
                    {
                      "key": "response_type",
                      "value": "<string>"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "<uri>"
                    }
                  ],
                  "variable": []
                },
                "method": "GET",
                "body": {}
              },
              "status": "Found",
              "code": 302,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ],
              "body": "",
              "cookie": [],
              "_postman_previewlanguage": "text"
            }
          ],
          "event": [],
